# Public build-time config (Vite inlines these; only PUBLIC values belong here).
# X OAuth 2.0 Client ID — public by design (PKCE); the client SECRET lives only in the
# backend's user-secrets (XAuth:ClientSecret) for the server-side code exchange.
VITE_X_CLIENT_ID=dzh3aHluY1lGektoOEhBMXJvOFg6MTpjaQ
# Google OAuth Client ID — public by design (the browser's GIS flow embeds it; the backend
# verifies ID tokens against Google's keys with this as the required audience).
VITE_GOOGLE_CLIENT_ID=232196999644-10ngilk9c3ar6n0tl54k04t7hi3r9lju.apps.googleusercontent.com
